{
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react",
		"jsxFactory": "React.createElement",
		"jsxFragmentFactory": "React.Fragment",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noImplicitAny": false,
		"declaration": true,
		"types": ["vitest/globals"]
	},
	"include": [
		"src/**/*",
		"vitest.config.ts",
		"vitest.setup.ts"
	],
	"exclude": [
		"src/**/*.stories.tsx",
		"src/**/*.test.tsx",
		"src/**/*.spec.tsx",
		"src/**/*.mdx"
	]
}