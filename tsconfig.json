{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react",
		"jsxFactory": "wp.element.createElement",
		"jsxFragmentFactory": "wp.element.Fragment",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noImplicitAny": false,
		"declaration": true
	},
	"exclude": [
		"node_modules",
		"dist",
		"templates"
	]
}