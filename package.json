{
	"name": "@doubleedesign/comet-gutenberg-controls",
	"version": "0.1.0",
	"author": "Leesa Ward",
	"homepage": "https://cometcomponents.io",
	"description": "Customised WordPress block editor controls for the Comet Components plugin",
	"type": "module",
	"main": "dist/index.dist.js",
	"exports": {
		".": "./dist/index.dist.js",
		"./style.css": "./dist/style.css"
	},
	"scripts": {
		"compile": "rollup -c",
		"lint": "eslint --fix",
		"build": "pnpm run compile && sass src/_style.scss:dist/style.css",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test": "vitest run src/components",
		"test:watch": "vitest watch src/components",
		"open:webstorm": "start http://localhost:63342/api/internal/action/navigateInBrowser?url=http://localhost:6006"
	},
	"devDependencies": {
		"@babel/eslint-parser": "^7.29.7",
		"@babel/plugin-syntax-dynamic-import": "^7.8.3",
		"@babel/preset-react": "^7.29.7",
		"@doubleedesign/doublee-site-style": "github:doubleedesign/doublee-site-style",
		"@doubleedesign/storybook-assorted-decorators": "^0.0.5",
		"@eslint/js": "^9.39.4",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@rollup/pluginutils": "^5.4.0",
		"@storybook/addon-a11y": "^10.4.2",
		"@storybook/addon-docs": "^10.4.2",
		"@storybook/addon-webpack5-compiler-swc": "^4.0.3",
		"@storybook/react-webpack5": "^10.4.2",
		"@stylistic/eslint-plugin-js": "^2.13.0",
		"@stylistic/eslint-plugin-ts": "^2.13.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/lodash-es": "^4.17.12",
		"@types/react": "^18.3.31",
		"@types/tinymce": "^4.6.9",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"@vitejs/plugin-react": "^6.0.2",
		"@wordpress/base-styles": "^9.1.0",
		"@wordpress/block-editor": "^15.21.0",
		"@wordpress/block-library": "^9.48.0",
		"@wordpress/blocks": "^15.21.0",
		"@wordpress/components": "^35.0.0",
		"@wordpress/data": "^10.48.0",
		"@wordpress/element": "^8.0.0",
		"@wordpress/hooks": "^4.48.0",
		"@wordpress/html-entities": "^4.48.0",
		"@wordpress/i18n": "^6.21.0",
		"@wordpress/icons": "^13.3.0",
		"@wordpress/rich-text": "^7.48.0",
		"@wordpress/server-side-render": "^6.24.0",
		"eslint": "^9.39.4",
		"glob": "^13.0.6",
		"happy-dom": "^20.10.2",
		"prismjs": "^1.30.0",
		"react": "^18.3.1",
		"react-syntax-highlighter": "^16.1.1",
		"rollup": "^4.61.1",
		"storybook": "^10.4.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vitest": "^4.1.8"
	},
	"pnpm": {
		"overrides": {
			"react": "^18.3.1",
			"react-dom": "^18.3.1"
		}
	}
}
